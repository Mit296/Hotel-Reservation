package ui;

import application.ReservationControl;
import java.util.Scanner;

public class ReservationUI {
    private ReservationControl control;
    private Scanner scanner = new Scanner(System.in); // 追加：入力を受け付けるコンソール

    public ReservationUI(ReservationControl control) {
        this.control = control;
    }

    public void inputstayDate() {
        System.out.println("\n=================================");
        System.out.println("  ◆ ホテル予約システムへようこそ ◆  ");
        System.out.println("=================================");
        System.out.print("宿泊日を入力してください（例: 20260709）: ");
        String date = scanner.nextLine(); // ユーザーの入力を待つ
        
        System.out.print("宿泊人数を入力してください: ");
        String count = scanner.nextLine();

        System.out.println("\n[入力された情報を基に空室を検索します]");
        control.confirmVacancy();
    }

    public void selectRoomAndInputGuestInfo() {
        System.out.println("\n--- 部屋の選択と宿泊者情報の入力 ---");
        System.out.print("希望する部屋番号を選択してください（例: 101）: ");
        String roomNum = scanner.nextLine();

        System.out.print("代表者の氏名を入力してください: ");
        String name = scanner.nextLine();

        control.confirmReservation();
    }

    public void comfirmReservatin() {
        System.out.println("\n予約を確定しますか？ (y/n): ");
        String answer = scanner.nextLine();
        if (answer.equalsIgnoreCase("y")) {
            control.confirmPossibleReservation();
            control.reserveRoom();
            control.createReservation();
            int resNum = control.getReservationNumber();
            showReservationNumber(resNum);
        } else {
            System.out.println("予約をキャンセルしました。");
        }
    }

    public void showReservationNumber(int num) {
        System.out.println("\n【予約完了】");
        System.out.println("あなたの予約番号は [ " + num + " ] です。");
        System.out.println("チェックインの際に必要となりますのでお控えください。");
    }
}
